{
  "name": "carelink",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm -w @carelink/mobile run start",
    "dev:api": "npm -w @carelink/api run dev",
    "build:mobile:web": "npm -w @carelink/mobile run export:web",
    "build:api": "npm -w @carelink/api run build",
    "typecheck": "npm -w @carelink/shared run typecheck && npm -w @carelink/api run typecheck",
    "mobile:android": "npm -w @carelink/mobile run android",
    "mobile:ios": "npm -w @carelink/mobile run ios",
    "mobile:web": "npm -w @carelink/mobile run web",
    "infra:up": "docker compose -f infra/docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.dev.yml down"
  }
}
