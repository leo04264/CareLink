{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitThis": false,

    "types": ["node", "react", "react-native"]
  },
  "include": ["App.tsx", "index.ts", "src/**/*"],
  "exclude": ["node_modules", "dist", "babel.config.js", "metro.config.js"]
}
