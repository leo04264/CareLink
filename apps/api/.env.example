# See spec/carelink-backend-spec.md §3. Copy to .env and fill in.
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
APP_VERSION=0.1.0

# Database (Postgres)
DATABASE_URL=postgresql://carelink:carelink@localhost:5432/carelink

# Redis
REDIS_URL=redis://localhost:6379

# JWT (spec §9)
JWT_SECRET=change-me-min-32-chars-change-me-min-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Expo Push (PR K). Default OFF so local dev doesn't hit Expo's servers.
# Flip to `true` in production / demo .env. See src/lib/expo-push.ts.
EXPO_PUSH_ENABLED=false

# Workers TZ — crons (spec §6) use server-local time. For caregivers in
# Taiwan we want 09:00 / 10:00 to be Taipei time, so set TZ on the
# worker process in production. Leave unset in dev (UTC) — all the
# scan times will shift accordingly but behavior is identical.
# TZ=Asia/Taipei

# Cloudflare R2 (spec §8) — leave empty until PR L
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=carelink-media
R2_PUBLIC_URL=
