# See spec/carelink-backend-spec.md §3. Copy to .env and fill in.
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
APP_VERSION=0.1.0

# Database (Postgres)
DATABASE_URL=postgresql://carelink:carelink@localhost:5432/carelink

# Redis
REDIS_URL=redis://localhost:6379

# JWT (spec §9)
JWT_SECRET=change-me-min-32-chars-change-me-min-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Expo Push (PR K). Default OFF so local dev doesn't hit Expo's servers.
# Flip to `true` in production / demo .env. See src/lib/expo-push.ts.
EXPO_PUSH_ENABLED=false

# Workers TZ — crons (spec §6) use server-local time. For caregivers in
# Taiwan we want 09:00 / 10:00 to be Taipei time, so set TZ on the
# worker process in production. Leave unset in dev (UTC) — all the
# scan times will shift accordingly but behavior is identical.
# TZ=Asia/Taipei

# S3-compatible storage (spec §5.10 + §8).
# Dev defaults target the MinIO container from infra/docker-compose.dev.yml.
# Switch to Cloudflare R2 in production by updating these 5 values — no
# code changes needed (both speak the same S3 API).
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=carelink-media
# Dev: MinIO serves objects at {endpoint}/{bucket}. Prod: your R2 public
# URL, e.g. https://pub-xxx.r2.dev
R2_PUBLIC_URL=http://localhost:9000/carelink-media
# R2 uses "auto"; MinIO doesn't care. Leave as-is.
R2_REGION=auto
