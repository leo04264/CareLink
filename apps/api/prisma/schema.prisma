// CareLink — Prisma schema
// Grows module by module. PR D adds just the models needed by /auth.
// Family / Elder CRUD lands in a later PR; this file only defines the
// minimum surface so register -> pair -> verify can flow end-to-end.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FamilyMemberRole {
  PRIMARY
  CAREGIVER
}

// ── User (子女 / caregiver) ────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     FamilyMember[]
  refreshTokens   RefreshToken[]
  notifications   Notification[]
  acknowledgedSos SosEvent[]            @relation("AcknowledgedBy")
  pushTokens      PushToken[]
  notifSettings   NotificationSetting?
  uploadedMedia   Media[]
}

// ── Opaque refresh tokens (rotated on each /auth/refresh) ──────────────────
model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ── Family + membership ────────────────────────────────────────────────────
model Family {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  members FamilyMember[]
  elders  Elder[]
}

model FamilyMember {
  id       String           @id @default(uuid())
  role     FamilyMemberRole @default(CAREGIVER)
  joinedAt DateTime         @default(now())

  userId   String
  familyId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([userId, familyId])
}

// ── Elder (長輩) ────────────────────────────────────────────────────────────
// Profile fields grow as later modules hang off Elder (checkins, medications,
// vitals, appointments, sos). PR E adds birthDate + avatarUrl.
model Elder {
  id          String    @id @default(uuid())
  name        String
  birthDate   DateTime?
  avatarUrl   String?
  createdAt   DateTime  @default(now())

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  // Device pairing
  pairCode          String?   @unique
  pairCodeExpiresAt DateTime?
  deviceToken       String?
  platform          String?

  checkins      Checkin[]
  medications   Medication[]
  healthVitals  HealthVital[]
  appointments  Appointment[]
  sosEvents     SosEvent[]
  uploadedMedia Media[]
}

// ── InviteToken ─────────────────────────────────────────────────────────────
// One-time-use token for `POST /family/:id/invite` → `POST /family/join`.
// 7-day TTL by default. Rows stay in DB after `usedAt` is set so we have an
// audit trail; GC can be added in PR K with other BullMQ crons.
model InviteToken {
  id          String    @id @default(uuid())
  token       String    @unique
  familyId    String
  createdById String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([familyId])
}

// ── Daily check-in ──────────────────────────────────────────────────────────
// Long-press 「我很好」 creates one row per press. We derive `today` /
// `streakDays` from these rows on demand (no denormalized state on Elder).
model Checkin {
  id        String   @id @default(uuid())
  checkedAt DateTime @default(now())
  note      String?

  elderId String
  elder   Elder  @relation(fields: [elderId], references: [id], onDelete: Cascade)

  @@index([elderId, checkedAt])
}

// ── Notification ────────────────────────────────────────────────────────────
// One row per recipient (fan-out happens at write time via `notifyFamily`).
// Push delivery (FCM/Expo) is deferred to PR K — we only write the DB row for
// now so the caregiver app can poll /notifications and see fresh items.
enum NotificationType {
  CHECKIN
  MEDICATION
  MEDICATION_MISSED
  SOS
  APPOINTMENT
  CHECKIN_OVERDUE
  VITALS_ALERT
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ── Medication ──────────────────────────────────────────────────────────────
enum MedicationFreq {
  DAILY
  EVERY_OTHER
  WEEKLY
  AS_NEEDED
}

enum MedicationStatus {
  ACTIVE
  PAUSED
  DELETED
}

model Medication {
  id            String           @id @default(uuid())
  name          String
  dosage        String?
  amountPerDose String?
  color         String?
  note          String?
  frequency     MedicationFreq   @default(DAILY)
  status        MedicationStatus @default(ACTIVE)
  pauseReason   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  elderId   String
  elder     Elder                @relation(fields: [elderId], references: [id], onDelete: Cascade)
  schedules MedicationSchedule[]
  logs      MedicationLog[]

  @@index([elderId, status])
}

model MedicationSchedule {
  id          String  @id @default(uuid())
  time        String  // "HH:MM"
  mealContext String?
  amountNote  String?
  isEnabled   Boolean @default(true)

  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId])
}

model MedicationLog {
  id           String   @id @default(uuid())
  takenAt      DateTime @default(now())
  photoUrl     String?
  confirmed    Boolean  @default(false)
  scheduleTime String?  // the HH:MM of the schedule this log fulfills

  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId, takenAt])
}

// ── Health vitals (BP + BS share the table) ─────────────────────────────────
enum HealthVitalType {
  BLOOD_PRESSURE
  BLOOD_SUGAR
}

model HealthVital {
  id           String          @id @default(uuid())
  type         HealthVitalType
  measuredAt   DateTime        @default(now())

  // BP (type = BLOOD_PRESSURE)
  systolic  Int?
  diastolic Int?

  // BS (type = BLOOD_SUGAR)
  glucoseValue Float?
  mealContext  String?

  elderId String
  elder   Elder  @relation(fields: [elderId], references: [id], onDelete: Cascade)

  @@index([elderId, type, measuredAt])
}

// ── Appointment ─────────────────────────────────────────────────────────────
enum AppointmentStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

model Appointment {
  id          String            @id @default(uuid())
  department  String
  hospital    String
  scheduledAt DateTime
  note        String?
  status      AppointmentStatus @default(UPCOMING)
  remindDays  Int[]             @default([1, 7])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  elderId String
  elder   Elder  @relation(fields: [elderId], references: [id], onDelete: Cascade)

  @@index([elderId, status, scheduledAt])
}

// ── User notification prefs ─────────────────────────────────────────────────
// One row per user. PUT endpoint upserts. Defaults are "all on, quiet
// 22:00–07:00" — created lazily by GET if the user hasn't saved yet.
model NotificationSetting {
  id String @id @default(uuid())

  checkin          Boolean @default(true)
  medication       Boolean @default(true)
  medicationMissed Boolean @default(true)
  sos              Boolean @default(true)
  appointment      Boolean @default(true)
  checkinOverdue   Boolean @default(true)
  vitalsAlert      Boolean @default(true)

  quietStart String? // "HH:MM" local — null disables quiet hours
  quietEnd   String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Push tokens ─────────────────────────────────────────────────────────────
// One user can have multiple devices (phone + tablet). `token` alone is
// globally unique; (userId, token) composite caught in assertions too.
model PushToken {
  id        String   @id @default(uuid())
  token     String   @unique
  platform  String // "ios" | "android" | "web"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── SOS event ───────────────────────────────────────────────────────────────
// One row per SOS press. Caregivers can acknowledge to stop re-alerting.
// Location stored as JSON string (spec §4 format).
model SosEvent {
  id             String    @id @default(uuid())
  triggeredAt    DateTime  @default(now())
  acknowledgedAt DateTime?
  location       String?

  elderId String
  elder   Elder  @relation(fields: [elderId], references: [id], onDelete: Cascade)

  acknowledgedById String?
  acknowledgedBy   User?   @relation("AcknowledgedBy", fields: [acknowledgedById], references: [id])

  @@index([elderId, triggeredAt])
}

// ── Media (spec §5.10 + §8) ────────────────────────────────────────────────
// One row per presigned-URL issuance. `key` is the S3 object path;
// `confirmedAt` flips to non-null after the client PUTs successfully and
// calls /media/confirm. Uploader is one of user or elder — never both.
model Media {
  id          String    @id @default(uuid())
  key         String    @unique
  contentType String
  context     String    // "medication-log" / "elder-avatar" / ...
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  uploaderUserId  String?
  uploaderUser    User?   @relation(fields: [uploaderUserId], references: [id], onDelete: SetNull)
  uploaderElderId String?
  uploaderElder   Elder?  @relation(fields: [uploaderElderId], references: [id], onDelete: SetNull)

  @@index([context, createdAt])
}
